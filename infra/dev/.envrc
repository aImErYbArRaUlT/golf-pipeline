# direnv: loaded automatically when you cd into infra/dev.
# No secrets here - it inherits the repo-root .env (via source_up) and just
# selects the environment. Run `direnv allow` once to trust it.
source_up                                   # load repo-root .envrc (-> .env)

export GOLF_ENV=dev
export TF_VAR_env=dev
export TF_VAR_project_id="${GCP_PROJECT_ID:?set GCP_PROJECT_ID in .env}"

# Sandbox: no billing -> authenticate via your own ADC, skip the SA.
# Flip to true (with a billing-enabled project) for real SA-based auth.
export TF_VAR_enable_service_account=false
