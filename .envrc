# Repo-root direnv config. Loads local secrets/config from .env (gitignored)
# and defaults the active pipeline environment. The infra/<env>/.envrc files
# inherit this via `source_up`. Run `direnv allow` once to trust it.

# Provision the reproducible Nix dev shell (toolchain pinned in flake.nix:
# toolbox, uv, just, opentofu, node, ...) when nix-direnv is available. Guarded
# so contributors without nix-direnv simply fall back to host tools - no error.
# (One-time enable: nix profile install nixpkgs#nix-direnv, then source its
#  direnvrc; on native Windows use WSL2.)
if has nix && declare -f use_flake >/dev/null 2>&1; then
  use flake
fi

dotenv_if_exists .env

# Active environment for pipeline commands (ingest/dbt) run from the root.
# Override per shell with `GOLF_ENV=prod ...` or by cd-ing into infra/<env>.
export GOLF_ENV="${GOLF_ENV:-dev}"
