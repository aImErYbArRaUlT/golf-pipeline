# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. .env is gitignored - never commit it.
# Every secret in the project is read from the environment, never
# hardcoded. This file documents WHICH variables exist (with safe
# placeholders), so a newcomer knows what to provide.
# ─────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────
# Active environment (dev/uat/prod). direnv sets this; datasets are
# namespaced <env>_<layer> (e.g. dev_bronze). Override per shell as needed.
GOLF_ENV=dev

# ── Google Cloud / BigQuery ──────────────────────────────────
# Your GCP project id (BigQuery free tier / sandbox is fine).
GCP_PROJECT_ID=your-gcp-project-id
# Region for the BigQuery datasets.
GCP_LOCATION=EU
# Service-account key path. LEAVE UNSET to use your own gcloud ADC (the
# sandbox path - no billing). With billing + a generated SA, point this at
# the key (keep it OUTSIDE the repo or in a gitignored path).
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json

# ── MinIO (local S3-compatible object storage) ───────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-locally
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver

# ── Ingestion sources ────────────────────────────────────────
# Override the per-source CSV URLs here. If unset, the code falls back to
# the documented public defaults in ingestion/golf_ingest/sources.py.
# TRACKMAN_CSV_URL=https://raw.githubusercontent.com/tim-blackmore/launch-monitor-regression/main/data.csv
# FORESIGHT_CSV_URL=https://raw.githubusercontent.com/jgamblin/golf/main/Data/DrivingRange-...csv
# CADDIESET_CSV_URL=https://raw.githubusercontent.com/damilab/CaddieSet/main/data/CaddieSet.csv
